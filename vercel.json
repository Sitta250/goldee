{
  "crons": [
    {
      "path":     "/api/scheduler/analysis",
      "schedule": "30 2 * * *"
    },
    {
      "path":     "/api/scheduler/analysis",
      "schedule": "0 11 * * *"
    },
    {
      "path":     "/api/scheduler/analysis",
      "schedule": "30 3 * * *"
    },
    {
      "path":     "/api/scheduler/analysis",
      "schedule": "0 12 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
