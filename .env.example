# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Pooled connection — used by Prisma at runtime (via connection pooling)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/goldee?sslmode=require&pgbouncer=true"

# Direct connection — used by Prisma Migrate and db push (bypasses PgBouncer)
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:5432/goldee?sslmode=require"

# ─── Cron Security ───────────────────────────────────────────────────────────
# Verified on every request to:
#   /api/scheduler/fetch        (host-agnostic scheduler endpoint)
#   /api/cron/fetch-gold-price  (legacy path, still supported)
#   /api/admin/run-fetch        (manual trigger — any environment)
# Generate with: openssl rand -hex 32
# Send as:
#   Authorization: Bearer <CRON_SECRET>
CRON_SECRET="replace-with-random-secret"

# ─── Gold Price Source ───────────────────────────────────────────────────────
# Which provider to use: mock | ygta
#
#   mock  — safe default for local dev; no external calls; deterministic fake data.
#   ygta  — real prices from สมาคมค้าทองคำ (YGTA / Gold Traders Association Thailand).
#
# To switch to real data locally, set BOTH variables:
#   GOLD_PROVIDER=ygta
#   GOLD_API_URL=https://www.goldtraders.or.th/UpdatePriceList.aspx
#
# If GOLD_PROVIDER=ygta but GOLD_API_URL is unset, development falls back to
# mock automatically (a warning is logged). Production uses the hardcoded
# YGTA endpoint without needing GOLD_API_URL, but setting it explicitly is
# recommended for auditability.
GOLD_PROVIDER="mock"

# YGTA price endpoint — can be overridden for testing/staging.
# Default (when unset): https://www.goldtraders.or.th/api/Latest?readjson=false
# GOLD_API_URL="https://www.goldtraders.or.th/api/GoldPrices/Latest?readjson=false"

# API key — not required for YGTA (their endpoint is public).
# Uncomment only if you switch to a commercial gold data API that requires auth.
# GOLD_API_KEY=""

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://goldee.vercel.app"
NEXT_PUBLIC_SITE_NAME="Goldee"

# ─── Optional: On-demand ISR revalidation ────────────────────────────────────
REVALIDATION_SECRET="replace-with-random-secret"
