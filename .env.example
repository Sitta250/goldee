# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Pooled connection — used by Prisma at runtime (via connection pooling)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/goldee?sslmode=require&pgbouncer=true"

# Direct connection — used by Prisma Migrate and db push (bypasses PgBouncer)
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:5432/goldee?sslmode=require"

# ─── Thai polling window (production/staging ingest) ─────────────────────────
# Scheduled price checks run only inside this window in Asia/Bangkok (24h clock).
# GitHub Actions cron should be narrowed to the matching UTC hours (see README).
# Outside the window, POST /api/scheduler/ingest and GET ingest routes return skipped.
#
#   SKIP_FETCH_WINDOW=1  — disable the window (emergency / staging)
#
# THAI_FETCH_START_HHMM="09:00"
# THAI_FETCH_END_HHMM="18:30"

# ─── Cron Security ───────────────────────────────────────────────────────────
# Verified on every request to:
#   /api/scheduler/fetch        (legacy pull-based scheduler endpoint)
#   /api/scheduler/ingest       (new push-based ingest endpoint)
#   /api/cron/fetch-gold-price  (legacy path, still supported)
#   /api/admin/run-fetch        (manual trigger — any environment)
# Generate with: openssl rand -hex 32
# Send as:
#   Authorization: Bearer <CRON_SECRET>
CRON_SECRET="9bc0c1a4ebdb9071f9c0c7ed80dfad091d5ea90ecfaf4b5b333833bb810906cc"

# ─── Gold Price Source ───────────────────────────────────────────────────────
# Which provider to use: mock | ygta
#
#   mock  — safe default for local dev; no external calls; deterministic fake data.
#   ygta  — real prices from สมาคมค้าทองคำ (YGTA / Gold Traders Association Thailand).
#
# To switch to real data locally, set BOTH variables:
#   GOLD_PROVIDER=ygta
#   GOLD_API_URL=https://www.goldtraders.or.th/api/GoldPrices/Latest?readjson=false
#
# If GOLD_PROVIDER=ygta but GOLD_API_URL is unset, development falls back to
# mock automatically (a warning is logged). Production uses the hardcoded
# YGTA endpoint without needing GOLD_API_URL, but setting it explicitly is
# recommended for auditability.
GOLD_PROVIDER="mock"

# YGTA price endpoint — can be overridden for testing/staging.
# Default (when unset): https://www.goldtraders.or.th/api/GoldPrices/Latest?readjson=false
# GOLD_API_URL="https://www.goldtraders.or.th/api/GoldPrices/Latest?readjson=false"

# ─── GitHub Actions secrets (reference) ───────────────────────────────────────
# Set these in GitHub Actions repo secrets (not as Vercel env vars):
#   CHNWT_API_URL=https://api.chnwt.dev/thai-gold-api
#   SCHEDULER_INGEST_URL=https://your-domain.com/api/scheduler/ingest

# API key — not required for YGTA (their endpoint is public).
# Uncomment only if you switch to a commercial gold data API that requires auth.
# GOLD_API_KEY=""

# ─── Gemini (Today Gold Analysis summary) ────────────────────────────────────
# Required for LLM summaries in /api/scheduler/analysis and /api/admin/run-analysis.
# Create a key: https://aistudio.google.com/apikey
# GEMINI_API_KEY="your-google-ai-studio-key"
#
# Optional — default is gemini-2.5-flash
# GEMINI_MODEL="gemini-2.5-flash"
#
# If the primary model keeps returning 503 (high demand), set a fallback; it runs
# after the primary exhausts all transient retries (same prompts).
# GEMINI_FALLBACK_MODEL="gemini-2.0-flash"
#
# Optional — for `npm run verify:analysis` HTTP check (dev server must be running):
# VERIFY_ANALYSIS_URL="http://localhost:3000"
#
# GitHub Actions — analysis backup crons (see .github/workflows/scheduler-analysis.yml):
#   ANALYSIS_CRON_URL — full URL, e.g. https://your-app.vercel.app/api/scheduler/analysis
#   CRON_SECRET — same bearer token as Vercel cron
#
# GitHub Actions — daily health check (.github/workflows/analysis-daily-health.yml):
#   DATABASE_URL — same pooled Postgres URL as production (read-only count query)

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://goldee.vercel.app"
NEXT_PUBLIC_SITE_NAME="Goldee"

# ─── Optional: On-demand ISR revalidation ────────────────────────────────────
REVALIDATION_SECRET="replace-with-random-secret"
