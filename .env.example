# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Pooled connection — used by Prisma at runtime (via connection pooling)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/goldee?sslmode=require&pgbouncer=true"

# Direct connection — used by Prisma Migrate and db push (bypasses PgBouncer)
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:5432/goldee?sslmode=require"

# ─── Cron Security ───────────────────────────────────────────────────────────
# Random secret verified on every /api/cron request.
# Generate with: openssl rand -hex 32
CRON_SECRET="replace-with-random-secret"

# ─── Gold Price Source ───────────────────────────────────────────────────────
# TODO: Replace with your chosen gold price data source
GOLD_API_URL="https://your-gold-data-source.example.com/api/price"
GOLD_API_KEY="your-api-key-if-required"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://goldee.vercel.app"
NEXT_PUBLIC_SITE_NAME="Goldee"

# ─── Optional: On-demand ISR revalidation ────────────────────────────────────
REVALIDATION_SECRET="replace-with-random-secret"
